NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
AGENCY_EMAIL=
AGENCY_IP_ADDRESS=
ADMIN_EMAILS=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Trigger.dev (automated website builds)
TRIGGER_SECRET_KEY=

# External webhook (forms on other sites)
WEBHOOK_API_KEY=
WEBHOOK_ALLOWED_ORIGINS=
WEBHOOK_RATE_LIMIT=10

# Client Task Management
PORTAL_JWT_SECRET=
ANTHROPIC_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Slack Integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ADMIN_USER_ID=
SLACK_BOT_USER_ID=

# Database (used by scripts/apply-migration.mjs and the reconciliation cron)
DATABASE_URL=

# Vercel Cron (optional — if set, /api/cron/* require this Bearer token)
CRON_SECRET=

# Dispatchr outbound webhook (Mission Control observability)
# When both vars are set, six lifecycle events fire to Dispatchr:
#   submission.new, build.dispatched, build.live, build.failed,
#   build.stuck, submission.abandoned
# If either is unset, every fire silently no-ops.
WEBSITEREVEALS_DISPATCHR_WEBHOOK_URL=https://joindispatchr.com/api/webhooks/websitereveals
WEBSITEREVEALS_DISPATCHR_WEBHOOK_SECRET=

# SiteLaunchr (build pipeline)
SITELAUNCHR_ENABLED=1
SITELAUNCHR_SOURCES=sales
SITELAUNCHR_API_URL=https://www.joinsitelaunchr.com/api/builds
SITELAUNCHR_API_KEY=
SITELAUNCHR_HMAC_SECRET=
SITELAUNCHR_CALLBACK_URL=https://www.websitereveals.com/api/sl-callback
SITELAUNCHR_ESTIMATED_COST_USD=4
SITELAUNCHR_TARGET_MINUTES=18
# Optional per-form-type overrides for cost estimation
SITELAUNCHR_COST_QUICK=
SITELAUNCHR_COST_STANDARD=
SITELAUNCHR_COST_IN_DEPTH=

# Template Site pipeline (isolated tpl_ module)
TEMPLATES_ENABLED=
APIFY_TOKEN=
# "table" persists builds for SL to read; "post" dispatches per-build to /api/builds.
SL_TEMPLATE_TRANSPORT=table
# Per-build endpoint for the wr-template source. Defaults to SITELAUNCHR_API_URL
# (/api/builds) if unset — wr-template hits the same endpoint as the wr source.
SL_TEMPLATE_BUILD_URL=
# wr-template is its OWN SL source — separate api key + HMAC secret from the wr source.
SL_TEMPLATE_API_KEY=
SL_TEMPLATE_HMAC_SECRET=
